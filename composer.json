{
  "name": "ton-nom/touche-pas-au-klaxon",
  "description": "Application PHP MVC de covoiturage inter-sites",
  "type": "project",
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "test": "phpunit -c phpunit.xml",
    "analyse": "phpstan analyse -c phpstan.neon"
  },
  "config": {
    "sort-packages": true
  }
}